# V5 environment variables. Copy to `.env` and fill in.
# .env is gitignored.

# --- OpenRouter / AI ---
OPENROUTER_API_KEY=
# Big model for watchlist selection (Prompt A). Heaviest reasoning + web research.
# "regular super grok" -- pair selection, multi-agent.
MODEL_WATCHLIST=x-ai/grok-4.20-multi-agent
# Fast model for the per-symbol decision (Prompt B). grok-4.1-fast.
MODEL_DEEP=x-ai/grok-4.1-fast
# Fast model for in-flight review hooks (Prompt C). Same as deep by default.
MODEL_REVIEW=x-ai/grok-4.1-fast
# Optional attribution headers recommended by OpenRouter.
OPENROUTER_REFERER=
OPENROUTER_TITLE=v5-paper-orchestrator

# --- Runtime switches ---
# Set to 1 to skip every test/call that hits the live exchange.
BYBIT_OFFLINE=
# Set to 1 to intercept AI calls with the mock router (real market data).
AI_DRY_RUN=
# Set to 1 to enable optional live AI tests (costs money).
OPENROUTER_LIVE=

# --- Paths / logging ---
# Absolute or relative to the V5/ folder. Default: V5/data.
DATA_ROOT=
LOG_LEVEL=INFO

# --- HTTP API / dashboard ---
# Default is loopback only. Set API_HOST=0.0.0.0 to expose on the VPS IP.
API_HOST=127.0.0.1
API_PORT=8765
