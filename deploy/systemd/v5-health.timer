[Unit]
Description=Run V5 health-check every 5 minutes

[Timer]
OnBootSec=2min
OnUnitActiveSec=5min
AccuracySec=30s
Persistent=true
Unit=v5-health.service

[Install]
WantedBy=timers.target[Unit]
Description=Run V5 health-check every 5 minutes

[Timer]
OnBootSec=2min
OnUnitActiveSec=5min
AccuracySec=30s
Persistent=true
Unit=v5-health.service

[Install]
WantedBy=timers.target
